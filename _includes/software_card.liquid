{% comment %}
  Single item — rendered once per project by repositories.md.
  Usage: {% include software_card.liquid project=project %}
{% endcomment %}
<style>
  .sw-item {
    display: flex;
    gap: 1.2rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--global-divider-color);
    align-items: flex-start;
  }

  .sw-item:last-child {
    border-bottom: none;
  }

  .sw-meta {
    min-width: 90px;
    text-align: right;
    flex-shrink: 0;
  }

  .sw-status,
  .sw-private {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    margin-bottom: 0.3rem;
    white-space: nowrap;
  }

  .sw-status {
    background: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #a5d6a7;
  }

  html[data-theme='dark'] .sw-status {
    background: #1b3a1f;
    color: #81c784;
    border-color: #388e3c;
  }

  .sw-private {
    background: #fff8e1;
    color: #f57f17;
    border: 1px solid #ffe082;
  }

  html[data-theme='dark'] .sw-private {
    background: #3a2e00;
    color: #ffd54f;
    border-color: #f9a825;
  }

  .sw-role-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--global-text-color-light);
  }

  .sw-body {
    flex: 1;
    min-width: 0;
  }

  .sw-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--global-text-color);
    margin-bottom: 0.2rem;
    line-height: 1.3;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .sw-title a {
    color: inherit;
    text-decoration: none;
  }

  .sw-title a:hover {
    text-decoration: underline;
  }

  .sw-title .sw-gh-icon {
    color: var(--global-text-color-light);
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .sw-company-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.73rem;
    color: var(--global-text-color-light);
    text-decoration: none;
    margin-bottom: 0.45rem;
    font-family: monospace;
  }

  .sw-company-link:hover {
    color: var(--global-text-color);
    text-decoration: underline;
  }

  .sw-desc {
    font-size: 0.85rem;
    color: var(--global-text-color);
    line-height: 1.55;
    margin: 0 0 0.5rem 0;
  }

  .sw-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }

  .sw-badge {
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.18rem 0.45rem;
    border-radius: 3px;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
</style>

<div class="sw-item">
  <div class="sw-meta">
    <span class="sw-status">software</span>
    {% if include.project.private %}
    <span class="sw-private">private</span>
    {% endif %}
    {% if include.project.role %}
    <span class="sw-role-label">{{ include.project.role }}</span>
    {% endif %}
  </div>

  <div class="sw-body">
    <div class="sw-title">
      <a href="{{ include.project.url }}" target="_blank" rel="noopener noreferrer">{{ include.project.name }}</a>
      <i class="fab fa-github sw-gh-icon"></i>
    </div>

    {% if include.project.company %}
    <a class="sw-company-link" href="{{ include.project.company_url }}" target="_blank" rel="noopener noreferrer">
      <i class="fas fa-building" style="font-size: 0.65rem;"></i>{{ include.project.company }}
    </a>
    {% endif %}

    <p class="sw-desc">{{ include.project.description }}</p>

    {% if include.project.languages %}
    <div class="sw-badges">
      {% for lang in include.project.languages %}
      <span class="sw-badge" style="background-color: {{ lang.color }}18; color: {{ lang.color }}; border: 1.5px solid {{ lang.color }}55;">
        <i class="{{ lang.icon }}" style="margin-right: 3px;"></i>{{ lang.name }}
      </span>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>
